# ============================================================
# KAVAN v6.0 — Environment Variables Template
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# CORE SETTINGS
# ----------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production-minimum-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ----------------------------------------------------------
# DATABASE (PostgreSQL)
# ----------------------------------------------------------
DB_ENGINE=django.db.backends.postgresql
DB_NAME=kavan_db
DB_USER=kavan_user
DB_PASSWORD=kavan_secure_password
DB_HOST=localhost
DB_PORT=5432

# Docker Compose DB host (use 'db' for docker-compose)
# DB_HOST=db

# ----------------------------------------------------------
# REDIS
# ----------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# Docker Compose Redis host:
# REDIS_URL=redis://redis:6379/0

# ----------------------------------------------------------
# CELERY
# ----------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Docker Compose:
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/1

# ----------------------------------------------------------
# EMAIL
# ----------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@kavan.com

# ----------------------------------------------------------
# API
# ----------------------------------------------------------
API_VERSION=v1
API_PAGINATION_PAGE_SIZE=20
API_MAX_PAGE_SIZE=100

# ----------------------------------------------------------
# LOGGING
# ----------------------------------------------------------
LOG_LEVEL=DEBUG
LOG_FILE=logs/app.log
SECURITY_LOG_FILE=logs/security.log
AUDIT_LOG_FILE=logs/audit.log
ERROR_LOG_FILE=logs/error.log

# ----------------------------------------------------------
# CORS
# ----------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_ALL_ORIGINS=False

# ----------------------------------------------------------
# SECURITY (Production)
# ----------------------------------------------------------
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# ----------------------------------------------------------
# STATIC / MEDIA
# ----------------------------------------------------------
STATIC_URL=/static/
MEDIA_URL=/media/
STATIC_ROOT=staticfiles/
MEDIA_ROOT=media/

# ----------------------------------------------------------
# APPLICATION
# ----------------------------------------------------------
APP_NAME=KAVAN
APP_VERSION=6.0.0
APP_ENV=development
COMPANY_NAME=KAVAN Technologies
